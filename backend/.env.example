APP_NAME="ocr-bills"
ENVIRONMENT="local"
JWT_SECRET="change-me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Set to use Google Vision OCR (optional).
# Requires enabling the Google Vision API and providing credentials via API key.
GOOGLE_VISION_API_KEY="AIzaSyB79grAUpDhwFfxVLvKyvC5RExdx6SeGbU"

# Storage
UPLOAD_DIR="./storage/uploads"

# Database
# Default local dev uses SQLite. Switch to Postgres by overriding DATABASE_URL.
DATABASE_URL="sqlite:///./storage/app.db"

# CORS (comma-separated; include both so localhost and 127.0.0.1 work)
FRONTEND_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

