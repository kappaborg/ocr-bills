APP_NAME="extasy"
ENVIRONMENT="local"
JWT_SECRET="change-me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── OCR engine ─────────────────────────────────────────────────────────────
# Pluggable. Switch values to swap engines — no code changes required.
#   tesseract — free, local, lowest accuracy. The current default.
#   gemini    — free tier 1500 req/day, top-tier accuracy on receipts.
#               Get a key at https://aistudio.google.com/app/apikey
#               and set GEMINI_API_KEY below, then change OCR_ENGINE to gemini.
#   claude    — stub. Implement in app/services/ocr_engines/claude.py
#   mindee    — stub. Purpose-built receipt API (~$0.05/receipt).
#   paddle    — stub. Local open-source, blocked by Py 3.14 wheels.
OCR_ENGINE="tesseract"
GEMINI_API_KEY=""
OCR_VLM_MODEL="gemini-2.5-flash"

# Legacy (unused now that OCR is pluggable). Kept blank to avoid old code paths.
GOOGLE_VISION_API_KEY=""

# Tesseract languages (only used when OCR_ENGINE=tesseract).
TESSERACT_LANGS="eng+rus+srp+srp_latn+bos+bul+ukr"

# Storage
UPLOAD_DIR="./storage/uploads"

# Database
# Default local dev uses SQLite. Switch to Postgres by overriding DATABASE_URL.
DATABASE_URL="sqlite:///./storage/app.db"

# CORS (comma-separated; include both so localhost and 127.0.0.1 work)
FRONTEND_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3737,http://127.0.0.1:3737"

# ── Billing (Stripe) ────────────────────────────────────────────────────────
# Leave blank for local dev — billing endpoints return 503 until configured.
# For production:
#   1. Create products + monthly recurring prices in the Stripe dashboard
#      (one for Pro, one for Business).
#   2. Set the keys + price IDs below. Use sk_test_… in dev, sk_live_… in prod.
#   3. For webhooks: `stripe listen --forward-to localhost:8765/billing/webhook`
#      (whsec_… signing secret) or configure via the Stripe dashboard.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# Quota overrides (0 = unlimited)
QUOTA_FREE_RECEIPTS_PER_MONTH=20
QUOTA_PRO_RECEIPTS_PER_MONTH=500
QUOTA_BUSINESS_RECEIPTS_PER_MONTH=0

# Pricing display in cents — shown on the pricing page, doesn't drive billing
PRICE_PRO_CENTS=499
PRICE_BUSINESS_CENTS=1999

# Used as the success/cancel return target for Stripe Checkout
FRONTEND_URL="http://localhost:3737"

